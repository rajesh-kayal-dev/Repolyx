# Server Listening Port
PORT=5000

# Environment Mode
NODE_ENV=development

# Frontend URL (for CORS and OAuth redirect checking)
FRONTEND_URL=http://localhost:3000

# Neon Database URL
DATABASE_URL="postgresql://username:password@hostname/dbname?sslmode=require"

# JSON Web Token Secret (used for signing tokens)
JWT_SECRET="generate-a-secure-random-secret-key-here"

# Express Session Secret
SESSION_SECRET="generate-a-secure-session-secret-key-here"

# GitHub OAuth Application Credentials
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# AI Provider - FreeModel (required for AI features)
FREEMODEL_API_KEY="your-freemodel-api-key"
FREEMODEL_BASE_URL="https://cc.freemodel.dev"

# AI Provider - Google Gemini (optional, alternative provider)
GEMINI_API_KEY="your-gemini-api-key"

# AI Provider - OpenRouter (optional, alternative provider)
OPENROUTER_API_KEY="your-openrouter-api-key"

# Redis Connection URL (For BullMQ background indexing queue)
# For Upstash Redis, format is usually: rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT:6379
REDIS_URL="redis://127.0.0.1:6379"
