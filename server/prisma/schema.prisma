generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(cuid())
  githubId          String          @unique
  username          String
  email             String?
  avatarUrl         String?
  githubAccessToken String?
  repositories      Repository[]
  chatSessions      ChatSession[]
  reviewSessions    ReviewSession[]
  debugIncidents    DebugIncident[]
  createdAt         DateTime        @default(now())
}

model Repository {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  githubRepoId   String               @unique
  name           String
  fullName       String
  visibility     String
  defaultBranch  String?
  language       String?
  description    String?
  cloneUrl       String?
  isIndexed      Boolean              @default(false)
  scanStatus     String               @default("pending")
  aiSummary      String?
  techStack      String?
  dependencyCount Int                 @default(0)
  fileCount      Int                  @default(0)
  branchCount    Int                  @default(0)
  lastScanAt     DateTime?
  lastScanDuration Int?
  files          RepositoryFile[]
  events         RepositoryEvent[]
  debugIncidents DebugIncident[]
  analyses       RepositoryAnalysis[]
  chatSessions   ChatSession[]
  aiContext      AIContext?
  reviewSessions ReviewSession[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model RepositoryFile {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  path         String
  name         String
  extension    String     @default("")
  size         Int        @default(0)
  type         String     @default("file")
  content      String?
  isImportant  Boolean    @default(false)
  aiAnalysis   String?
  modulePurpose String?
  createdAt    DateTime   @default(now())

  @@unique([repositoryId, path])
}

model RepositoryEvent {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  type         String
  message      String
  metadata     Json?
  createdAt    DateTime   @default(now())
}

model RepositoryAnalysis {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  type         String
  summary      String?
  data         Json?
  createdAt    DateTime   @default(now())
}

model ChatSession {
  id           String        @id @default(cuid())
  repositoryId String
  repository   Repository    @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  messages     ChatMessage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // 'user' | 'assistant'
  content   String
  provider  String? // 'freemodel' | 'gemini' | 'openrouter'
  model     String? // e.g. 'claude-sonnet-4-6'
  createdAt DateTime    @default(now())
}

model Session {
  id        String   @id @default(cuid())
  sid       String   @unique
  data      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model AIContext {
  id                String     @id @default(cuid())
  repositoryId      String     @unique
  repository        Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  activeFile        String?
  relatedFiles      Json?
  repositorySummary String?
  metadata          Json?
  createdAt         DateTime   @default(now())
}

model ReviewSession {
  id             String             @id @default(cuid())
  repositoryId   String
  repository     Repository         @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  prUrl          String?
  prNumber       Int?
  title          String
  baseBranch     String?
  headBranch     String?
  author         String?
  status         String             @default("pending")
  riskLevel      String?
  testCoverage   String?
  ciStatus       String?
  mergeReady     Int                @default(0)
  summary        String?
  report         String?
  metadata       Json?
  files          ReviewFile[]
  suggestions    ReviewSuggestion[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model ReviewFile {
  id              String        @id @default(cuid())
  reviewSessionId String
  reviewSession   ReviewSession @relation(fields: [reviewSessionId], references: [id], onDelete: Cascade)
  path            String
  status          String        @default("modified")
  risk            String?
  additions       Int           @default(0)
  deletions       Int           @default(0)
  patch           String?
  content         String?
  comments        Int           @default(0)
  createdAt       DateTime      @default(now())

  @@unique([reviewSessionId, path])
}

model ReviewSuggestion {
  id              String        @id @default(cuid())
  reviewSessionId String
  reviewSession   ReviewSession @relation(fields: [reviewSessionId], references: [id], onDelete: Cascade)
  filePath        String?
  type            String        @default("quality")
  title           String
  description     String
  severity        String        @default("medium")
  lineStart       Int?
  lineEnd         Int?
  codeSnippet     String?
  createdAt       DateTime      @default(now())
}

model DebugIncident {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositoryId     String?
  repository       Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  title            String
  impactStatement  String?
  severity         String      @default("medium") // critical | high | medium | low
  status           String      @default("investigating") // investigating | identified | monitoring | resolved
  source           String      @default("manual") // manual | auto-scan
  service          String?
  deployVersion    String?
  errorRate        String?
  affectedUsers    String?
  aiSummary        String?
  aiProblem        String?
  aiImpact         String?
  aiRecommendations Json?      // string[]
  aiExplanation    String?     // legacy
  aiFixSuggestion  String?     // legacy
  aiConfidence     Int         @default(0) // 0-100
  riskLevel        String?     // low | medium | high
  affectedFiles    Json?       // string[]
  relatedCommits   Json?       // { sha, message, author }[]
  timelineEvents   Json?       // { type, title, detail, timestamp }[]
  resolvedAt       DateTime?
  logs             DebugLog[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model DebugLog {
  id         String        @id @default(cuid())
  incidentId String?
  incident   DebugIncident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  userId     String
  level      String        @default("info") // error | warn | info
  message    String
  source     String        @default("unknown")
  service    String?
  stackTrace String?
  metadata   Json?
  loggedAt   DateTime      @default(now())
  createdAt  DateTime      @default(now())
}