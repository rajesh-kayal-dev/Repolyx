{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "browsermcp": {
      "type": "local",
      "command": ["npx", "@browsermcp/mcp@latest"],
      "enabled": true
    },
    "apify": {
      "type": "remote",
      "url": "https://mcp.apify.com",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    },
    "render": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "mcp-remote", "https://mcp.render.com/mcp", "--header", "Authorization: Bearer rnd_D6xn0kaQL0iPq3dtXf77GXBCbiHD"],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-filesystem", "D:\\AI Projects\\Repolyx"],
      "enabled": true
    }
  }
}
